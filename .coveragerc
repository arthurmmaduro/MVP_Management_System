# coverage configuration
[run]
branch = True
parallel = True
omit =
    */migrations/*,
    */.venv/*,
    */__pycache__/*,
    *.venv/*,
    venv/*,
    env/*,
    utils/browser.py,
    manage.py,
    */test/*,
    */tests/*

[report]
show_missing = True
skip_covered = False
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    if __name__ == .__main__.:
    raise NotImplementedError
    pass

[html]
directory = htmlcov
